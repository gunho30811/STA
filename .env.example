SAMSAM_EMAIL=
SAMSAM_PASSWORD=

# 삼삼엠투 통합채팅(여러 계정 연결) 암호화 키. 연결 계정 비번·Firebase refreshToken을
# samsam_accounts 테이블에 암호화 저장할 때 씀(crypto_util.py, Fernet).
# 생성: python -c "import os,base64;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# 주의: 웹(Vercel)과 폴링 워크플로(GH Actions secret) 양쪽에 반드시 같은 값이어야 함
# (다르면 이미 연결된 계정의 암호문을 복호화하지 못함).
CHAT_ENC_KEY=

# Supabase Postgres 연결 문자열
# Supabase 콘솔 > Project Settings > Database > Transaction pooler URI 사용
# (Direct connection은 IPv6 전용이라 한국 일반망에서 접속 불가)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# 로그인/세션 (필수). 5001~5003 로그인 공유하려면 모든 앱이 같은 값을 써야 함.
#   생성: python -c "import os;print(os.urandom(24).hex())"
SECRET_KEY=
# 관리자 계정(미설정 시 기본 gunho / rjsgh1004!). init_db 첫 실행 때 1회 시드.
ADMIN_USERNAME=gunho
ADMIN_PASSWORD=

# 이메일 인증 실발송(미설정 시 목 모드: 코드가 화면/로그에 표시됨).
# Gmail: 2단계인증 켜고 "앱 비밀번호"(16자) 발급해서 SMTP_PASS에 사용.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
